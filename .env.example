# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=beginagain

# (Only needed if NOT using Docker Compose for database)
# DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/beginagain?schema=public

# ==========================================
# BACKEND SERVICES CONFIGURATION
# ==========================================
PORT=4000
JWT_SECRET=some_strong_jwt_secret_phrase

# ==========================================
# DOMAINS / CORS CONFIGURATION
# ==========================================
# URL of your frontend (e.g. https://beginagain.inspiredliving.in)
FRONTEND_URL=http://localhost:8080

# URL of your backend API (client-side reachable, e.g. https://api.inspiredliving.in/api/v1)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ==========================================
# NODEMAILER / SMTP CONFIGURATION
# ==========================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ==========================================
# PAYU PAYMENT GATEWAY CONFIGURATION
# ==========================================
MERCHANT_KEY=your_payu_merchant_key
MERCHANT_SALT=your_payu_merchant_salt
# Set to 'TEST' for sandbox/testing or 'LIVE' for production transactions
PAYU_ENVIRONMENT=TEST
